{
  "name": "road-trip-trivia-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A TypeScript trivia game application built with Vite for those fun road trips.",
  "author": {
    "name": "Jorge Barnaby",
    "email": "jorge.barnaby@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yorch/road-trip-trivia-game.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
